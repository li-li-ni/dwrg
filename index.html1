<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>第五人格胜率预测</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="container">
        <h1>第五人格胜率预测</h1>
        
        <div class="form-section">
            <h2>输入信息</h2>
            
            <div class="form-group">
                <label for="team-type">求生者组排情况：</label>
                <select id="team-type" onchange="updateForm()">
                    <option value="4-solo">四个单排</option>
                    <option value="1-duo-2-solo">一个双排两个单排</option>
                    <option value="1-trio-1-solo">一个三排一个单排</option>
                    <option value="1-quad">一个四排</option>
                </select>
            </div>
            
            <div id="survivor-inputs">
                <!-- 动态生成的求生者胜率输入框 -->
            </div>
            
            <div class="form-group">
                <label for="hunter-winrate">监管者胜率：</label>
                <input type="number" id="hunter-winrate" min="0" max="100" step="0.1" placeholder="例如：52.5">
                <span class="unit">%</span>
            </div>
            
            <button onclick="calculate()">计算胜率</button>
        </div>
        
        <div class="result-section">
            <h2>预测结果</h2>
            <div id="results">
                <!-- 计算结果将显示在这里 -->
            </div>
            <div class="note">
                <p>注：此计算方式，默认组排的各个求生者胜率相同。</p>
            </div>
        </div>
    </div>
    
    <script src="script.js"></script>
</body>
</html>
